# TP-Link account (email). Kept for reference; NOT used by the local API.
USERNAME=your-tplink-account@example.com
# Deco admin password (the TP-Link account password). Used for local auth.
PASSWORD=your-deco-password

# Optional (defaults shown)
DECO_HOST=http://172.16.1.1
# Local account name used to build the request-signature hash. Normally "admin".
ACCOUNT=admin
VERIFY_SSL=false
TIMEOUT=30
